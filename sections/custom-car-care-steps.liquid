<section class="nx-simple-steps">
  <div class="nx-simple-wrap">
    <h2>{{ section.settings.heading }}</h2>

    <div class="nx-simple-card">
      {% for block in section.blocks %}
        <div class="nx-simple-item" {{ block.shopify_attributes }}>
          <div class="nx-icon-box">
            <span class="nx-step-number">{{ forloop.index }}</span>

            {% if block.settings.icon != blank %}
              <img src="{{ block.settings.icon | image_url: width: 120 }}" alt="{{ block.settings.title | escape }}">
            {% else %}
              <div class="nx-fallback-icon">✦</div>
            {% endif %}
          </div>

          <div class="nx-simple-text">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>

        {% unless forloop.last %}
          <div class="nx-simple-arrow">→</div>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
.nx-simple-steps {
  background: #050b0f;
  padding: 24px 20px 34px;
  color: #fff;
}

.nx-simple-wrap {
  max-width: 1500px;
  margin: 0 auto;
}

.nx-simple-wrap h2 {
  text-align: center;
  color: #fff;
  font-size: 30px;
  font-weight: 900;
  margin: 0 0 14px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.nx-simple-card {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
  align-items: center;
  gap: 22px;
  padding: 28px 36px;
  border-radius: 14px;
  background:
linear-gradient(
90deg,
#051105 0%,
#0b1f0c 20%,
#12300f 50%,
#0b1f0c 80%,
#051105 100%
);
  border: 1px solid rgba(255,255,255,.06);
  box-shadow: inset 0 0 35px rgba(255,255,255,.03), 0 18px 45px rgba(0,0,0,.35);
}

.nx-simple-item {
  display: flex;
  align-items: center;
  gap: 20px;
  min-width: 0;
}

.nx-icon-box {
  position: relative;
  width: 84px;
  min-width: 84px;
  height: 84px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nx-icon-box img {
  width: 72px;
  height: 72px;
  object-fit: contain;
  filter: brightness(0) invert(1);
}

.nx-fallback-icon {
  color: #fff;
  font-size: 48px;
}

.nx-step-number {
  position: absolute;
  top: -8px;
  left: -6px;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(0, 88, 165, .18);
  border: 2px solid #006fc9;
  color: #1c8cff;
  font-size: 14px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nx-simple-text h3 {
  margin: 0 0 7px;
  color: #fff;
  font-size: 20px;
  font-weight: 900;
  text-transform: uppercase;
}

.nx-simple-text p {
  margin: 0;
  color: #d8e0e8;
  font-size: 14px;
  line-height: 1.45;
  max-width: 190px;
}

.nx-simple-arrow {
  color: #fff;
  font-size: 46px;
  line-height: 1;
  opacity: .9;
  font-weight: 300;
}

@media (max-width: 1100px) {
  .nx-simple-card {
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .nx-simple-arrow {
    transform: rotate(90deg);
    text-align: center;
    font-size: 36px;
  }

  .nx-simple-item {
    justify-content: flex-start;
  }

  .nx-simple-text p {
    max-width: none;
  }
}

@media (max-width: 600px) {
  .nx-simple-wrap h2 {
    font-size: 23px;
  }

  .nx-simple-card {
    padding: 22px 18px;
  }

  .nx-icon-box {
    width: 68px;
    min-width: 68px;
    height: 68px;
  }

  .nx-icon-box img {
    width: 58px;
    height: 58px;
  }

  .nx-simple-text h3 {
    font-size: 17px;
  }
}
</style>

{% schema %}
{
  "name": "Car Care Made Simple",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CAR CARE MADE SIMPLE"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "WASH"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Remove dirt & grime with our powerful foam and shampoo."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Car Care Made Simple",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "WASH",
            "text": "Remove dirt & grime with our powerful foam and shampoo."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "CLEAN",
            "text": "Deep clean surfaces inside and out safely."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "PROTECT",
            "text": "Shine, protect and repel for a long lasting finish."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "ENJOY",
            "text": "Enjoy that fresh, clean car feeling every time."
          }
        }
      ]
    }
  ]
}
{% endschema %}