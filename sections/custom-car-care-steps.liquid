<section class="nx-simple-steps">
  <div class="nx-simple-wrap">
    <h2>{{ section.settings.heading }}</h2>

    <div class="nx-simple-card">
      {% for block in section.blocks %}
        <div class="nx-simple-item" {{ block.shopify_attributes }}>
          <div class="nx-icon-box">
            <span class="nx-step-number">{{ forloop.index }}</span>

            {% if block.settings.icon != blank %}
              <img src="{{ block.settings.icon | image_url: width: 120 }}" alt="{{ block.settings.title | escape }}">
            {% else %}
              <div class="nx-fallback-icon">✦</div>
            {% endif %}
          </div>

          <div class="nx-simple-text">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>

        {% unless forloop.last %}
          <div class="nx-simple-arrow">→</div>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
@property --nx-border-angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}

.nx-simple-steps {
  background:
    linear-gradient(
      180deg,
      #020402 0%,
      #051005 50%,
      #020402 100%
    );
  padding: 26px 20px 38px;
  color: #fff;
}

.nx-simple-wrap {
  max-width: 1500px;
  margin: 0 auto;
}

.nx-simple-wrap h2 {
  text-align: center;
  color: #fff;
  font-size: 30px;
  font-weight: 900;
  margin: 0 0 14px;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-shadow: 0 0 12px rgba(126, 211, 33, .22);
}

.nx-simple-card {
  position: relative;
  overflow: hidden;
  isolation: isolate;

  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
  align-items: center;
  gap: 22px;

  padding: 28px 36px;
  border-radius: 16px;

  background:
    linear-gradient(
      90deg,
      #050805 0%,
      #071407 25%,
      #0b1d0b 50%,
      #071407 75%,
      #050805 100%
    );

  border: 1px solid rgba(255, 255, 255, .045);

  box-shadow:
    0 8px 25px rgba(0, 0, 0, .38);
}

.nx-simple-card::before {
  content: "";
  position: absolute;
  inset: 0;
  padding: 1.5px;
  border-radius: 16px;

  background:
    conic-gradient(
      from var(--nx-border-angle),
      transparent 0deg,
      transparent 245deg,
      rgba(180, 255, 120, .08) 275deg,
      rgba(180, 255, 120, .55) 315deg,
      rgba(180, 255, 120, .08) 350deg,
      transparent 360deg
    );

  -webkit-mask:
    linear-gradient(#000 0 0) content-box,
    linear-gradient(#000 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;

  animation: nxBorderSpin 6s linear infinite;
  pointer-events: none;
  z-index: -1;
}

@keyframes nxBorderSpin {
  from {
    --nx-border-angle: 0deg;
  }
  to {
    --nx-border-angle: 360deg;
  }
}

.nx-simple-item {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 20px;
  min-width: 0;
}

.nx-icon-box {
  position: relative;
  width: 84px;
  min-width: 84px;
  height: 84px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nx-icon-box img {
  width: 72px;
  height: 72px;
  object-fit: contain;
  filter: brightness(0) invert(1);
}

.nx-fallback-icon {
  color: #fff;
  font-size: 44px;
  text-shadow: 0 0 8px rgba(126, 211, 33, .22);
}

.nx-step-number {
  position: absolute;
  top: -8px;
  left: -6px;
  width: 28px;
  height: 28px;
  border-radius: 50%;

  background: rgba(126, 211, 33, .10);
  border: 2px solid rgba(148, 216, 75, .62);
  color: #ffffff;

  font-size: 14px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nx-simple-text h3 {
  margin: 0 0 7px;
  color: #fff;
  font-size: 20px;
  font-weight: 900;
  text-transform: uppercase;
}

.nx-simple-text p {
  margin: 0;
  color: #dce8d8;
  font-size: 14px;
  line-height: 1.45;
  max-width: 190px;
}

.nx-simple-arrow {
  position: relative;
  z-index: 2;
  color: #94d84b;
  opacity: .72;
  font-size: 46px;
  line-height: 1;
  font-weight: 300;
  text-shadow: none;
}

@media (max-width: 1100px) {
  .nx-simple-card {
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .nx-simple-arrow {
    transform: rotate(90deg);
    text-align: center;
    font-size: 36px;
  }

  .nx-simple-item {
    justify-content: flex-start;
  }

  .nx-simple-text p {
    max-width: none;
  }
}

@media (max-width: 600px) {
  .nx-simple-steps {
    padding: 24px 14px 34px;
  }

  .nx-simple-wrap h2 {
    font-size: 23px;
  }

  .nx-simple-card {
    padding: 22px 18px;
  }

  .nx-icon-box {
    width: 68px;
    min-width: 68px;
    height: 68px;
  }

  .nx-icon-box img {
    width: 58px;
    height: 58px;
  }

  .nx-simple-text h3 {
    font-size: 17px;
  }

  .nx-simple-text p {
    font-size: 13px;
  }
}
</style>

{% schema %}
{
  "name": "Car Care Made Simple",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CAR CARE MADE SIMPLE"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "WASH"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Remove dirt & grime with our powerful foam and shampoo."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Car Care Made Simple",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "WASH",
            "text": "Remove dirt & grime with our powerful foam and shampoo."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "CLEAN",
            "text": "Deep clean surfaces inside and out safely."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "PROTECT",
            "text": "Shine, protect and repel for a long lasting finish."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "ENJOY",
            "text": "Enjoy that fresh, clean car feeling every time."
          }
        }
      ]
    }
  ]
}
{% endschema %}