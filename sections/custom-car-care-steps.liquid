<section class="nx-simple-steps">
  <div class="nx-simple-wrap">
    <h2>{{ section.settings.heading }}</h2>

    <div class="nx-simple-card">
      {% for block in section.blocks %}
        <div class="nx-simple-item" {{ block.shopify_attributes }}>
          <div class="nx-icon-box">
            <span class="nx-step-number">{{ forloop.index }}</span>

            {% if block.settings.icon != blank %}
              <img src="{{ block.settings.icon | image_url: width: 120 }}" alt="{{ block.settings.title | escape }}">
            {% else %}
              <div class="nx-fallback-icon">✦</div>
            {% endif %}
          </div>

          <div class="nx-simple-text">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>

        {% unless forloop.last %}
          <div class="nx-simple-arrow">→</div>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
.nx-simple-steps {
  background:
    radial-gradient(circle at 20% 20%, rgba(124,255,0,.16), transparent 28%),
    radial-gradient(circle at 80% 60%, rgba(124,255,0,.12), transparent 30%),
    linear-gradient(180deg, #020602 0%, #061306 50%, #020602 100%);
  padding: 26px 20px 38px;
  color: #fff;
}

.nx-simple-wrap {
  max-width: 1500px;
  margin: 0 auto;
}

.nx-simple-wrap h2 {
  text-align: center;
  color: #fff;
  font-size: 30px;
  font-weight: 900;
  margin: 0 0 14px;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-shadow: 0 0 16px rgba(124,255,0,.35);
}

.nx-simple-card {
  position: relative;
  overflow: hidden;

  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
  align-items: center;
  gap: 22px;

  padding: 28px 36px;
  border-radius: 15px;

  background:
  linear-gradient(
    90deg,
    #050805 0%,
    #071407 25%,
    #0b1d0b 50%,
    #071407 75%,
    #050805 100%
  );

  border: 1px solid rgba(126,211,33,.15);

  box-shadow:
    0 8px 25px rgba(0,0,0,.35);
}

.nx-simple-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 8%;
  width: 84%;
  height: 2px;
 background: linear-gradient(
90deg,
transparent,
#7ed321,
transparent
);
}

.nx-simple-card::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
  pointer-events: none;
}

.nx-simple-item {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 20px;
  min-width: 0;
}

.nx-icon-box {
  position: relative;
  width: 84px;
  min-width: 84px;
  height: 84px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nx-icon-box img {
  width: 72px;
  height: 72px;
  object-fit: contain;
  filter: brightness(0) invert(1);
}

.nx-fallback-icon {
  color: #fff;
  font-size: 48px;
  text-shadow: 0 0 12px rgba(124,255,0,.45);
}

.nx-step-number {
  position: absolute;
  top: -8px;
  left: -6px;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(126,211,33,.12);
  border: 2px solid #7ed321;
  color: #ffffff;
  font-size: 14px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
}

.nx-simple-text h3 {
  margin: 0 0 7px;
  color: #fff;
  font-size: 20px;
  font-weight: 900;
  text-transform: uppercase;
}

.nx-simple-text p {
  margin: 0;
  color: #dce8d8;
  font-size: 14px;
  line-height: 1.45;
  max-width: 190px;
}

.nx-simple-arrow {
  position: relative;
  z-index: 2;
  color: #7ed321;
  font-size: 46px;
  line-height: 1;
  opacity: .7;
  font-weight: 300;
  text-shadow:none;
}

@media (max-width: 1100px) {
  .nx-simple-card {
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .nx-simple-arrow {
    transform: rotate(90deg);
    text-align: center;
    font-size: 36px;
  }

  .nx-simple-item {
    justify-content: flex-start;
  }

  .nx-simple-text p {
    max-width: none;
  }
}

@media (max-width: 600px) {
  .nx-simple-steps {
    padding: 24px 14px 34px;
  }

  .nx-simple-wrap h2 {
    font-size: 23px;
  }

  .nx-simple-card {
    padding: 22px 18px;
  }

  .nx-icon-box {
    width: 68px;
    min-width: 68px;
    height: 68px;
  }

  .nx-icon-box img {
    width: 58px;
    height: 58px;
  }

  .nx-simple-text h3 {
    font-size: 17px;
  }

  .nx-simple-text p {
    font-size: 13px;
  }
}
</style>

{% schema %}
{
  "name": "Car Care Made Simple",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CAR CARE MADE SIMPLE"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "WASH"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Remove dirt & grime with our powerful foam and shampoo."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Car Care Made Simple",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "WASH",
            "text": "Remove dirt & grime with our powerful foam and shampoo."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "CLEAN",
            "text": "Deep clean surfaces inside and out safely."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "PROTECT",
            "text": "Shine, protect and repel for a long lasting finish."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "ENJOY",
            "text": "Enjoy that fresh, clean car feeling every time."
          }
        }
      ]
    }
  ]
}
{% endschema %}