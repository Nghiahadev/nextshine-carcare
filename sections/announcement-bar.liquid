<div class="nextshine-announcement">
  <div class="nextshine-marquee">
    <div class="nextshine-marquee-track">

      {% for i in (1..20) %}
        {% for block in section.blocks %}
          <span class="nextshine-item" {{ block.shopify_attributes }}>

            {% if block.settings.icon != blank %}
              <span class="nextshine-icon-box">
                <img
                  src="{{ block.settings.icon | image_url: width: 90 }}"
                  alt=""
                  class="nextshine-icon"
                  loading="lazy"
                >
              </span>
            {% endif %}

            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}">
                {{ block.settings.text | escape }}
              </a>
            {% else %}
              <span>{{ block.settings.text | escape }}</span>
            {% endif %}

          </span>
        {% endfor %}
      {% endfor %}

    </div>
  </div>
</div>

<style>
.nextshine-announcement {
  width: 100%;
  height: 42px;
  overflow: hidden;
  background: #38a800;
  display: flex;
  align-items: center;
  white-space: nowrap;
}

.nextshine-marquee {
  width: 100%;
  overflow: hidden;
}

.nextshine-marquee-track {
  display: flex;
  align-items: center;
  width: max-content;
  animation: nextshineMarquee 200s linear infinite;
}

.nextshine-item {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 0 50px;
  color: #ffffff;
  font-size: 14px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.35px;
  line-height: 1;
}

.nextshine-icon-box {
  width: 30px;
  height: 30px;
  border: 1px solid rgba(255,255,255,0.65);
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(255,255,255,0.12);
}

.nextshine-icon {
  width: 20px;
  height: 20px;
  object-fit: contain;
  filter: brightness(0) invert(1);
}

.nextshine-item a,
.nextshine-item span {
  color: #ffffff;
  text-decoration: none;
}

.nextshine-announcement:hover .nextshine-marquee-track {
  animation-play-state: paused;
}

@keyframes nextshineMarquee {
  from {
    transform: translateX(0);
  }

  to {
    transform: translateX(-50%);
  }
}

@media screen and (max-width: 749px) {
  .nextshine-announcement {
    height: 36px;
  }

  .nextshine-marquee-track {
    animation-duration: 200s;
  }

  .nextshine-item {
    padding: 0 28px;
    gap: 8px;
    font-size: 10px;
  }

  .nextshine-icon-box {
    width: 24px;
    height: 24px;
  }

  .nextshine-icon {
    width: 15px;
    height: 15px;
  }
}
</style>

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "default": "Free shipping on orders $75+",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Free Shipping on Orders $75+"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "Premium Car Care Products"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "30 Day Returns"
          }
        }
      ]
    }
  ]
}
{% endschema %}
