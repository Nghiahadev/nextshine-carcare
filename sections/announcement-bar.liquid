<div class="nextshine-announcement">
  <div class="nextshine-marquee">
    <div class="nextshine-marquee-track">

      {% for i in (1..20) %}
        {% for block in section.blocks %}
          <span class="nextshine-item" {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}">
                {{ block.settings.text | escape }}
              </a>
            {% else %}
              {{ block.settings.text | escape }}
            {% endif %}
          </span>
        {% endfor %}
      {% endfor %}

    </div>
  </div>
</div>

<style>
.nextshine-announcement {
  width: 100%;
  overflow: hidden;
  background: #38a800;
  height: 34px;
  display: flex;
  align-items: center;
  white-space: nowrap;
}

.nextshine-marquee {
  width: 100%;
  overflow: hidden;
}

.nextshine-marquee-track {
  display: flex;
  align-items: center;
  width: max-content;
  animation: marqueeScroll 40s linear infinite;
}

.nextshine-item {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  padding: 0 48px;
  color: #fff;
  font-size: 13px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .3px;
}

.nextshine-item::before {
  content: "✦";
  margin-right: 28px;
  font-size: 12px;
}

.nextshine-item a {
  color: #fff;
  text-decoration: none;
}

.nextshine-announcement:hover .nextshine-marquee-track {
  animation-play-state: paused;
}

@keyframes marqueeScroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}

/* Mobile */
@media screen and (max-width: 749px) {
  .nextshine-announcement {
    height: 30px;
  }

  .nextshine-item {
    padding: 0 32px;
    font-size: 10px;
  }

  .nextshine-item::before {
    margin-right: 18px;
  }

  .nextshine-marquee-track {
    animation-duration: 25s;
  }
}
</style>

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Free shipping on orders $75+",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Free shipping on orders $75+"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "Premium car care. Cleaner results."
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "30 day returns"
          }
        }
      ]
    }
  ]
}
{% endschema %}
