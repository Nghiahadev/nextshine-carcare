<!-- TEST UPDATE -->
<div class="nextshine-announcement">
  <div class="nextshine-marquee">
    <div class="nextshine-marquee-track">
      {% for block in section.blocks %}
        <span class="nextshine-item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
          {% else %}
            {{ block.settings.text | escape }}
          {% endif %}
        </span>
      {% endfor %}

      {% for block in section.blocks %}
        <span class="nextshine-item">
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
          {% else %}
            {{ block.settings.text | escape }}
          {% endif %}
        </span>
      {% endfor %}
    </div>
  </div>
</div>

<style>
.nextshine-announcement {
  width: 100%;
  height: 32px;
  overflow: hidden;
  background: #39a900;
  color: #fff;
  display: flex;
  align-items: center;
  font-size: 12px;
  font-weight: 800;
  text-transform: uppercase;
  white-space: nowrap;
}

.nextshine-marquee {
  width: 100%;
  overflow: hidden;
}

.nextshine-marquee-track {
  display: flex;
  width: max-content;
  animation: nextshine-infinite-scroll 18s linear infinite;
}

.nextshine-item {
  flex: 0 0 auto;
  padding: 0 45px;
  color: #fff;
}

.nextshine-item::before {
  content: "✦";
  margin-right: 18px;
  color: #fff;
}

.nextshine-item a {
  color: #fff;
  text-decoration: none;
}

.nextshine-announcement:hover .nextshine-marquee-track {
  animation-play-state: paused;
}

@keyframes nextshine-infinite-scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

@media screen and (max-width: 749px) {
  .nextshine-announcement {
    height: 30px;
    font-size: 10px;
  }

  .nextshine-item {
    padding: 0 28px;
  }
}
</style>

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Free shipping on orders $75+",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Free shipping on orders $75+"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "Premium car care. Cleaner results."
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "30 day returns"
          }
        }
      ]
    }
  ]
}
{% endschema %}