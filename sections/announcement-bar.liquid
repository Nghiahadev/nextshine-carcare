<!-- TEST UPDATE -->
<div class="nextshine-announcement">
  <div class="nextshine-marquee">
    <div class="nextshine-marquee-track">
      {% for block in section.blocks %}
        <span class="nextshine-item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
          {% else %}
            {{ block.settings.text | escape }}
          {% endif %}
        </span>
      {% endfor %}

      {% for block in section.blocks %}
        <span class="nextshine-item">
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
          {% else %}
            {{ block.settings.text | escape }}
          {% endif %}
        </span>
      {% endfor %}
    </div>
  </div>
</div>

<style>
.nextshine-announcement {
  width: 100%;
  background: linear-gradient(90deg, #3d8b00, #79d600, #3d8b00);
  color: #fff;
  height: 34px;
  overflow: hidden;
  display: flex;
  align-items: center;
  border-bottom: 1px solid rgba(255,255,255,.15);
  font-family: inherit;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .4px;
  font-size: 12px;
  z-index: 50;
}

.nextshine-marquee {
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
}

.nextshine-marquee-track {
  display: inline-flex;
  align-items: center;
  gap: 70px;
  animation: nextshine-scroll 22s linear infinite;
  will-change: transform;
}

.nextshine-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.nextshine-item::before {
  content: "✦";
  color: #fff;
  font-size: 11px;
}

.nextshine-item a {
  color: #fff;
  text-decoration: none;
}

.nextshine-announcement:hover .nextshine-marquee-track {
  animation-play-state: paused;
}

@keyframes nextshine-scroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}

@media screen and (max-width: 749px) {
  .nextshine-announcement {
    height: 32px;
    font-size: 11px;
  }

  .nextshine-marquee-track {
    gap: 45px;
    animation-duration: 18s;
  }
}
</style>

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Free shipping on orders $75+",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Free shipping on orders $75+"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "Premium car care. Cleaner results."
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "30 day returns"
          }
        }
      ]
    }
  ]
}
{% endschema %}