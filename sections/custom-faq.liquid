<section class="nextshine-faq">
  <div class="faq-title">
    <span></span>
    <h2>Frequently Asked Questions</h2>
    <span></span>
  </div>

  <div class="faq-wrap">
    <div class="faq-image-box">
      <img id="faqImage" src="{{ section.settings.image_1 | image_url: width: 900 }}" alt="FAQ Image">
    </div>

    <div class="faq-list">
      {% for block in section.blocks %}
        <div class="faq-item {% if forloop.first %}active{% endif %}" 
             data-image="{{ block.settings.faq_image | image_url: width: 900 }}">
          <button class="faq-question">
            {{ block.settings.question }}
            <span class="faq-icon">{% if forloop.first %}−{% else %}+{% endif %}</span>
          </button>
          <div class="faq-answer" {% unless forloop.first %}style="display:none"{% endunless %}>
            {{ block.settings.answer }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.nextshine-faq {
  padding: 40px 20px;
  background: #fff;
}

.faq-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  margin-bottom: 20px;
}

.faq-title span {
  width: 55px;
  height: 2px;
  background: #77bd1f;
}

.faq-title h2 {
  font-size: 18px;
  text-transform: uppercase;
  font-weight: 800;
  margin: 0;
  letter-spacing: .5px;
}

.faq-wrap {
  max-width: 1200px;
  margin: auto;
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 28px;
  align-items: stretch;
}

.faq-image-box {
  border-radius: 12px;
  overflow: hidden;
  height: 300px;
}

.faq-image-box img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: opacity .25s ease;
}

.faq-list {
  border: 1px solid #e6e6e6;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 3px 10px rgba(0,0,0,.06);
}

.faq-item {
  border-bottom: 1px solid #e6e6e6;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  width: 100%;
  border: none;
  background: #fff;
  padding: 18px 22px;
  text-align: left;
  font-weight: 800;
  font-size: 15px;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.faq-icon {
  color: #77bd1f;
  font-size: 26px;
  font-weight: 700;
}

.faq-answer {
  padding: 0 22px 20px;
  font-size: 14px;
  line-height: 1.7;
  color: #333;
  background: #fafafa;
}

@media (max-width: 768px) {
  .faq-wrap {
    grid-template-columns: 1fr;
  }

  .faq-image-box {
    height: 230px;
  }

  .faq-title h2 {
    font-size: 15px;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const items = document.querySelectorAll(".faq-item");
  const faqImage = document.getElementById("faqImage");

  items.forEach(item => {
    const button = item.querySelector(".faq-question");

    button.addEventListener("click", function () {
      items.forEach(i => {
        i.classList.remove("active");
        i.querySelector(".faq-answer").style.display = "none";
        i.querySelector(".faq-icon").textContent = "+";
      });

      item.classList.add("active");
      item.querySelector(".faq-answer").style.display = "block";
      item.querySelector(".faq-icon").textContent = "−";

      const newImage = item.getAttribute("data-image");
      if (newImage && faqImage) {
        faqImage.style.opacity = "0";
        setTimeout(() => {
          faqImage.src = newImage;
          faqImage.style.opacity = "1";
        }, 180);
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "FAQ Image Accordion",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Default Image"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "faq_image",
          "label": "Image for this question"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Are your products safe for all car surfaces?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Yes! Our products are pH balanced and safe for paint, plastic, rubber, glass, and other exterior and interior surfaces."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Image Accordion"
    }
  ]
}
{% endschema %}