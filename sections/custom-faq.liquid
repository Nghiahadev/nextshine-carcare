<section class="nx-faq-section">
  <div class="nx-faq-container">

    <div class="nx-faq-header">
      <span>NEED HELP?</span>
      <h2>Frequently Asked Questions</h2>
      <p>Find quick answers about our products, shipping, returns, and car care tips.</p>
    </div>

    <div class="nx-faq-wrapper">
      {% for block in section.blocks %}
        <div class="nx-faq-item" {{ block.shopify_attributes }}>
          <button class="nx-faq-question" type="button">
            <span>{{ block.settings.question }}</span>
            <div class="nx-faq-icon">+</div>
          </button>

          <div class="nx-faq-answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
.nx-faq-section {
  background: radial-gradient(circle at top, #0f2b0b, #050505 60%);
  padding: 90px 20px;
  color: #fff;
}

.nx-faq-container {
  max-width: 1050px;
  margin: 0 auto;
}

.nx-faq-header {
  text-align: center;
  margin-bottom: 50px;
}

.nx-faq-header span {
  color: #58d900;
  font-weight: 900;
  letter-spacing: 2px;
  font-size: 13px;
}

.nx-faq-header h2 {
  font-size: clamp(36px, 5vw, 58px);
  margin: 12px 0;
  font-weight: 900;
  text-transform: uppercase;
}

.nx-faq-header p {
  color: #cfcfcf;
  max-width: 620px;
  margin: 0 auto;
  line-height: 1.7;
}

.nx-faq-wrapper {
  display: grid;
  gap: 18px;
}

.nx-faq-item {
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(88,217,0,.25);
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 20px 45px rgba(0,0,0,.25);
  opacity: 0;
  transform: translateY(35px);
  animation: nxFaqFadeUp .7s ease forwards;
}

.nx-faq-item:nth-child(1) { animation-delay: .1s; }
.nx-faq-item:nth-child(2) { animation-delay: .2s; }
.nx-faq-item:nth-child(3) { animation-delay: .3s; }
.nx-faq-item:nth-child(4) { animation-delay: .4s; }
.nx-faq-item:nth-child(5) { animation-delay: .5s; }

@keyframes nxFaqFadeUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.nx-faq-question {
  width: 100%;
  background: transparent;
  border: none;
  color: #fff;
  padding: 24px 28px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  text-align: left;
  cursor: pointer;
  font-size: 18px;
  font-weight: 800;
}

.nx-faq-question span {
  padding-right: 20px;
}

.nx-faq-icon {
  width: 38px;
  height: 38px;
  background: linear-gradient(135deg, #58d900, #158f00);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  flex-shrink: 0;
  transition: .35s ease;
}

.nx-faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height .45s ease;
}

.nx-faq-answer p {
  color: #d8d8d8;
  padding: 0 28px 25px;
  margin: 0;
  line-height: 1.8;
  font-size: 15px;
}

.nx-faq-item.active {
  background: rgba(88,217,0,.09);
  border-color: rgba(88,217,0,.55);
}

.nx-faq-item.active .nx-faq-icon {
  transform: rotate(45deg);
  background: #fff;
  color: #158f00;
}

@media (max-width: 700px) {
  .nx-faq-section {
    padding: 60px 15px;
  }

  .nx-faq-question {
    padding: 20px;
    font-size: 16px;
  }

  .nx-faq-answer p {
    padding: 0 20px 22px;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const faqItems = document.querySelectorAll(".nx-faq-item");

  faqItems.forEach((item) => {
    const question = item.querySelector(".nx-faq-question");
    const answer = item.querySelector(".nx-faq-answer");

    question.addEventListener("click", () => {
      const isOpen = item.classList.contains("active");

      faqItems.forEach((faq) => {
        faq.classList.remove("active");
        faq.querySelector(".nx-faq-answer").style.maxHeight = null;
      });

      if (!isOpen) {
        item.classList.add("active");
        answer.style.maxHeight = answer.scrollHeight + "px";
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "NextShine FAQ",
  "settings": [],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Most orders ship within 1–3 business days. Delivery time depends on your location."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NextShine FAQ",
      "blocks": [
        {
          "type": "faq"
        },
        {
          "type": "faq"
        },
        {
          "type": "faq"
        },
        {
          "type": "faq"
        }
      ]
    }
  ]
}
{% endschema %}