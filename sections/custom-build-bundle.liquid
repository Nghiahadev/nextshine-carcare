<section class="nx-bundle-banner">
  <div class="nx-bundle-wrap">

    <div class="nx-bundle-image">
      {% if section.settings.badge_text != blank %}
        <div class="nx-bundle-badge">{{ section.settings.badge_text }}</div>
      {% endif %}

      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.heading | escape }}">
      {% endif %}
    </div>

    <div class="nx-bundle-content">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="nx-bundle-btn">
          {{ section.settings.button_label }} <span>→</span>
        </a>
      {% endif %}
    </div>

    <div class="nx-bundle-features">
      {% for block in section.blocks %}
        <div class="nx-bundle-feature" {{ block.shopify_attributes }}>
          <div class="nx-feature-icon">
            {% if block.settings.icon != blank %}
              <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="{{ block.settings.title | escape }}">
            {% else %}
              ✦
            {% endif %}
          </div>

          <div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
.nx-bundle-banner {
  background:
    radial-gradient(circle at left, rgba(126,211,33,.16), transparent 34%),
    linear-gradient(90deg, #020602 0%, #041504 45%, #020602 100%);
  padding: 0 20px;
  color: #fff;
}

.nx-bundle-wrap {
  max-width: 1500px;
  margin: 0 auto;
  min-height: 310px;
  display: grid;
  grid-template-columns: 1.1fr 1fr 1.15fr;
  align-items: center;
  gap: 40px;
  border-top: 1px solid rgba(126,211,33,.28);
  border-bottom: 1px solid rgba(126,211,33,.18);
  padding: 28px 0;
}

.nx-bundle-image {
  position: relative;
  min-height: 250px;
  display: flex;
  align-items: center;
}

.nx-bundle-image img {
  width: 100%;
  max-height: 280px;
  object-fit: contain;
}

.nx-bundle-badge {
  position: absolute;
  top: 14px;
  left: 10px;
  width: 78px;
  height: 78px;
  border-radius: 50%;
  background: linear-gradient(135deg, #7ed321, #4fb000);
  color: #fff;
  font-size: 22px;
  line-height: 1.05;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-shadow: 0 0 25px rgba(126,211,33,.35);
}

.nx-bundle-content h2 {
  margin: 0 0 18px;
  font-size: 44px;
  line-height: 1.05;
  font-weight: 900;
  text-transform: uppercase;
  color: #fff;
}

.nx-bundle-content p {
  margin: 0 0 24px;
  color: #dce8d8;
  font-size: 16px;
  line-height: 1.6;
  max-width: 430px;
}

.nx-bundle-btn {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  background: #5fc400;
  color: #fff;
  text-decoration: none;
  padding: 14px 26px;
  border-radius: 5px;
  font-weight: 900;
  font-size: 14px;
  text-transform: uppercase;
  transition: .3s ease;
}

.nx-bundle-btn:hover {
  background: #7ed321;
  transform: translateY(-2px);
}

.nx-bundle-features {
  display: flex;
  flex-direction: column;
  gap: 28px;
  border-left: 1px solid rgba(126,211,33,.22);
  padding-left: 42px;
}

.nx-bundle-feature {
  display: grid;
  grid-template-columns: 70px 1fr;
  gap: 20px;
  align-items: center;
}

.nx-feature-icon {
  width: 58px;
  height: 58px;
  border: 2px solid rgba(255,255,255,.8);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  clip-path: polygon(25% 5%, 75% 5%, 100% 50%, 75% 95%, 25% 95%, 0% 50%);
}

.nx-feature-icon img {
  width: 34px;
  height: 34px;
  object-fit: contain;
  filter: brightness(0) invert(1);
}

.nx-bundle-feature h3 {
  margin: 0 0 6px;
  color: #fff;
  font-size: 18px;
  font-weight: 900;
  text-transform: uppercase;
}

.nx-bundle-feature p {
  margin: 0;
  color: #dce8d8;
  font-size: 14px;
  line-height: 1.5;
}

@media (max-width: 990px) {
  .nx-bundle-wrap {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .nx-bundle-image {
    justify-content: center;
  }

  .nx-bundle-content p {
    margin-left: auto;
    margin-right: auto;
  }

  .nx-bundle-features {
    border-left: none;
    padding-left: 0;
    max-width: 600px;
    margin: 0 auto;
    text-align: left;
  }
}

@media (max-width: 600px) {
  .nx-bundle-content h2 {
    font-size: 34px;
  }

  .nx-bundle-feature {
    grid-template-columns: 56px 1fr;
  }

  .nx-feature-icon {
    width: 48px;
    height: 48px;
  }
}
</style>

{% schema %}
{
  "name": "Bundle Promo Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product bundle image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "SAVE 15%"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "COMPLETE CARE.\nMAXIMUM RESULTS."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Get everything you need in one kit and save more with our premium bundles."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP BUNDLES"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Feature icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "PERFECTLY MATCHED PRODUCTS"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Curated combinations for the best results."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundle Promo Banner",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "PERFECTLY MATCHED PRODUCTS",
            "text": "Curated combinations for the best results."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "BETTER VALUE",
            "text": "Save more compared to buying separately."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "IDEAL FOR EVERY CAR LOVER",
            "text": "Great for beginners and pros alike."
          }
        }
      ]
    }
  ]
}
{% endschema %}