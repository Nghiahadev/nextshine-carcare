<script>
document.addEventListener("DOMContentLoaded", function () {
  const cardsWrapper = document.querySelector(".nextshine-glow-cards");
  const cards = Array.from(document.querySelectorAll(".nextshine-glow-inner:not(.nextshine-glow-overlay) .nextshine-card"));
  const overlay = document.querySelector(".nextshine-glow-overlay");

  if (!cardsWrapper || !overlay || cards.length === 0) return;

  overlay.innerHTML = "";

  cards.forEach(function(card) {
    const clone = card.cloneNode(true);
    overlay.appendChild(clone);
  });

  function syncOverlaySizes() {
    const overlayCards = overlay.querySelectorAll(".nextshine-card");

    cards.forEach(function(card, index) {
      const rect = card.getBoundingClientRect();
      if (overlayCards[index]) {
        overlayCards[index].style.height = rect.height + "px";
      }
    });
  }

  syncOverlaySizes();
  window.addEventListener("resize", syncOverlaySizes);

  cardsWrapper.addEventListener("pointermove", function(e) {
    const rect = cardsWrapper.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;

    overlay.style.setProperty("--opacity", "1");
    overlay.style.setProperty("--x", x + "px");
    overlay.style.setProperty("--y", y + "px");
  });

  cardsWrapper.addEventListener("pointerleave", function() {
    overlay.style.setProperty("--opacity", "0");
  });
});
</script>

