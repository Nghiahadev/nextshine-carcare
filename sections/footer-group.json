ns-newsletter-form input::placeholder{\n    color:#ddd;\n  }\n\n  .ns-newsletter-form button{\n    background:transparent;\n    border:0;\n    outline:none;\n    cursor:pointer;\n    color:#fff;\n    font-size:18px;\n  }\n\n  .ns-social-icons a{\n    width:40px;\n    height:40px;\n    border-radius:50%;\n    text-align:center;\n    line-height:40px;\n    font-size:18px;\n    color:#13a113;\n    background:#fff;\n    margin-right:10px;\n    display:inline-block;\n    text-decoration:none;\n    transition:0.4s;\n  }\n\n  .ns-social-icons a:hover{\n    transform:translateY(-5px);\n    background:#d9ffd9;\n  }\n\n  .ns-footer hr{\n    width:90%;\n    border:0;\n    border-bottom:1px solid #ccc;\n    margin:20px auto;\n  }\n\n  .ns-copyright{\n    text-align:center;\n    font-size:14px;\n    color:#fff;\n  }\n\n  .ns-underline{\n    width:100%;\n    height:5px;\n    background:#ffffff55;\n    border-radius:3px;\n    position:absolute;\n    top:30px;\n    left:0;\n    overflow:hidden;\n  }\n\n  .ns-underline span{\n    width:18px;\n    height:100%;\n    background:#fff;\n    border-radius:3px;\n    position:absolute;\n    top:0;\n    left:10px;\n    animation:ns-moving 2s linear infinite;\n  }\n\n  @keyframes ns-moving{\n    0%{ left:-20px; }\n    100%{ left:100%; }\n  }\n\n  @media (max-width:700px){\n    .ns-footer{\n      border-top-left-radius:60px;\n      padding:70px 0 30px;\n    }\n\n    .ns-footer-col,\n    .ns-footer-col:nth-child(2),\n    .ns-footer-col:nth-child(3){\n      flex-basis:100%;\n    }\n  }\n</style>\n\n<footer class=\"ns-footer\">\n  <div class=\"ns-footer-row\">\n\n    <div class=\"ns-footer-col\">\n      {% if settings.logo != blank %}\n        <img src=\"{{ settings.logo | image_url: width: 180 }}\" class=\"ns-footer-logo\" alt=\"{{ shop.name }}\">\n      {% endif %}\n\n      <p>\n        Premium car care products designed to clean, protect, and restore your vehicle's showroom shine.\n        From detailing essentials to advanced protection, Next