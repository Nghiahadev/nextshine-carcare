<section class="why-choose">
  <div class="why-choose__container">

    <div class="why-left">
      <h2>
        <span class="why-highlight">WHY CHOOSE</span><br>
        NEXTSHINE CAR CARE?
      </h2>

      <p>{{ section.settings.description }}</p>

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="btn5">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <div class="why-right">
      {% for block in section.blocks %}
        <div class="why-item" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <img
              src="{{ block.settings.icon | image_url: width: 120 }}"
              alt=""
              class="why-icon"
              loading="lazy"
            >
          {% endif %}

          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
.why-choose {
  background: linear-gradient(90deg, #031103 0%, #072207 35%, #0c330c 70%, #031103 100%);
  padding: 70px 5%;
  overflow: hidden;
}

.why-choose__container {
  max-width: 1400px;
  margin: auto;
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 40px;
  align-items: center;
}

.why-left {
  padding-right: 35px;
  border-right: 1px solid rgba(181, 211, 52, 0.3);
}

.why-left h2 {
  margin: 0 0 20px;
  color: #ffffff;
  font-size: 42px;
  line-height: 1.15;
  font-weight: 900;
  text-transform: uppercase;
}

.why-highlight {
  color: #B5D334;
}

.why-left p {
  color: #d8d8d8;
  font-size: 16px;
  line-height: 1.8;
  margin-bottom: 30px;
}

.why-right {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
}

.why-item {
  text-align: center;
  padding: 0 25px;
}

.why-item:not(:last-child) {
  border-right: 1px solid rgba(181, 211, 52, 0.18);
}

.why-icon {
  width: 58px;
  height: 58px;
  object-fit: contain;
  margin-bottom: 18px;
}

.why-item h3 {
  color: #ffffff;
  font-size: 15px;
  font-weight: 800;
  text-transform: uppercase;
  margin-bottom: 12px;
}

.why-item p {
  color: #d0d0d0;
  font-size: 14px;
  line-height: 1.7;
}

.btn5 {
  --color: #B5D334;
  padding: 0.85em 1.8em;
  background: transparent;
  border-radius: 4px;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  transition: 0.5s;
  font-weight: 800;
  font-size: 15px;
  border: 1px solid var(--color);
  text-transform: uppercase;
  text-decoration: none;
  display: inline-block;
  color: var(--color);
  z-index: 1;
}

.btn5::before,
.btn5::after {
  content: "";
  position: absolute;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: var(--color);
  z-index: -1;
  transition: 1s ease;
}

.btn5::before {
  top: -20px;
  left: -20px;
}

.btn5::after {
  right: -20px;
  bottom: -20px;
}

.btn5:hover::before,
.btn5:hover::after {
  width: 420px;
  height: 420px;
}

.btn5:hover {
  color: #031103;
  box-shadow: 0 0 18px rgba(181, 211, 52, 0.45);
}

.btn5:active {
  transform: scale(0.97);
}

@media (max-width: 991px) {
  .why-choose__container {
    grid-template-columns: 1fr;
  }

  .why-left {
    border-right: none;
    padding-right: 0;
    text-align: center;
  }

  .why-right {
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
  }

  .why-item {
    border: none !important;
    padding: 0;
  }
}

@media (max-width: 576px) {
  .why-left h2 {
    font-size: 32px;
  }

  .why-right {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "Why Choose Us",
  "settings": [
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We combine advanced formulas with premium tools to deliver unmatched results and make car care simple, effective, and satisfying."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Advanced Formulas"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "High performance ingredients for superior cleaning."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}