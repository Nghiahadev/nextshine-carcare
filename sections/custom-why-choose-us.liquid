<section class="why-choose">
  <div class="why-choose__container">

    <div class="why-left">

      <h2 class="why-title">
        <span>WHY CHOOSE</span>
        {{ section.settings.heading }}
      </h2>

      <p>
        {{ section.settings.description }}
      </p>

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="learn-btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}

    </div>

    <div class="why-right">

      {% for block in section.blocks %}
        <div class="why-item" {{ block.shopify_attributes }}>

          {% if block.settings.icon != blank %}
            <img
              src="{{ block.settings.icon | image_url: width: 120 }}"
              alt="{{ block.settings.title }}"
              class="why-icon"
            >
          {% endif %}

          <h3>{{ block.settings.title }}</h3>

          <p>{{ block.settings.text }}</p>

        </div>
      {% endfor %}

    </div>

  </div>
</section>

<style>

.why-choose{
  background: linear-gradient(
    90deg,
    #071b08 0%,
    #0a250c 35%,
    #0f4013 70%,
    #071b08 100%
  );
  padding: 60px 5%;
}

.why-choose__container{
  max-width: 1400px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 340px 1fr;
  align-items: center;
  gap: 40px;
}

.why-left{
  padding-right: 40px;
  border-right: 1px solid rgba(255,255,255,.15);
}

.why-title{
  margin: 0 0 20px;
  font-size: 42px;
  line-height: 1.1;
  text-transform: uppercase;
  font-weight: 800;
  color: #fff;
}

.why-title span{
  display: block;
  color: #38A800;
  margin-bottom: 4px;
}

.why-left p{
  color: rgba(255,255,255,.75);
  font-size: 15px;
  line-height: 1.8;
  margin-bottom: 30px;
}

.learn-btn{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #38A800;
  color: #ffffff;
  text-decoration: none;
  padding: 14px 26px;
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  border-radius: 4px;
  transition: .3s ease;
}

.learn-btn:after{
  content: "➜";
}

.learn-btn:hover{
  background: #42c000;
  transform: translateY(-2px);
}

.why-right{
  display: grid;
  grid-template-columns: repeat(4,1fr);
}

.why-item{
  text-align: center;
  padding: 0 25px;
  position: relative;
}

.why-item:not(:last-child){
  border-right: 1px solid rgba(255,255,255,.12);
}

.why-icon{
  width: 52px;
  height: 52px;
  object-fit: contain;
  margin-bottom: 18px;
  filter: brightness(0) invert(1);
}

.why-item h3{
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 10px;
  letter-spacing: .5px;
}

.why-item p{
  color: rgba(255,255,255,.70);
  font-size: 14px;
  line-height: 1.7;
  max-width: 180px;
  margin: 0 auto;
}

@media screen and (max-width: 991px){

  .why-choose__container{
    grid-template-columns: 1fr;
  }

  .why-left{
    border-right: none;
    padding-right: 0;
    text-align: center;
  }

  .why-right{
    grid-template-columns: repeat(2,1fr);
    gap: 30px;
  }

  .why-item{
    border: none !important;
    padding: 0;
  }
}

@media screen and (max-width: 767px){

  .why-title{
    font-size: 32px;
  }

  .why-right{
    grid-template-columns: 1fr;
  }

}

</style>

{% schema %}
{
  "name": "Why Choose Us",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "NEXTSHINE CAR CARE?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We combine advanced formulas with premium tools to deliver unmatched results and make your car care simple, effective, and satisfying."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Advanced Formulas"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "High performance ingredients for superior cleaning."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        }
      ]
    }
  ]
}
{% endschema %}