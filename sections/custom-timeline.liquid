<section class="nextshine-timeline-section">
  <div class="timeline-heading">
    <span></span>
    <h2>{{ section.settings.heading }}</h2>
    <span></span>
  </div>

  <div class="nextshine-timeline">
    {% for block in section.blocks %}
      <article class="timeline-card">
        <div class="timeline__content">
          <h3>{{ block.settings.title }}</h3>
          <time>{{ block.settings.year }}</time>
          <hr>
          <p>{{ block.settings.text }}</p>
        </div>

        {% if block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.title }}">
        {% endif %}
      </article>
    {% endfor %}
  </div>
</section>

<style>
.nextshine-timeline-section {
  background: #fff;
  color: #111;
  padding: 60px 20px;
}

.timeline-heading {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 14px;
  margin-bottom: 35px;
}

.timeline-heading span {
  width: 60px;
  height: 2px;
  background: #77bd1f;
}

.timeline-heading h2 {
  margin: 0;
  font-size: 22px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: .5px;
}

.nextshine-timeline {
  max-width: 900px;
  margin: auto;
}

.timeline-card {
  --size: 12px;
  --green: #77bd1f;

  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 35px;
  margin-top: -1px;
  padding-bottom: 28px;

  background:
    radial-gradient(circle closest-side, var(--green) calc(100% - 1px), transparent)
    50% 0 / var(--size) var(--size),
    linear-gradient(var(--green), var(--green)) 50% 0 / 2px 100%;
  background-repeat: no-repeat;
}

.timeline-card:first-child {
  background:
    linear-gradient(var(--green), var(--green))
    50% 0 / var(--size) calc(.5 * var(--size)),
    linear-gradient(var(--green), var(--green)) 50% 0 / 2px 100%;
  background-repeat: no-repeat;
}

.timeline-card:nth-child(odd) img {
  grid-area: 1 / 1;
  justify-self: end;
}

.timeline__content {
  background: #f8f8f8;
  border: 1px solid #e8e8e8;
  padding: 22px;
  border-radius: 14px;
  box-shadow: 0 8px 22px rgba(0,0,0,.06);
}

.timeline__content h3 {
  margin: 0 0 10px;
  color: #77bd1f;
  font-size: 22px;
  font-weight: 800;
}

.timeline__content time {
  display: block;
  font-size: 38px;
  line-height: 1.1;
  font-weight: 900;
  color: #111;
}

.timeline__content hr {
  border: none;
  border-top: 1px solid #ddd;
  margin: 14px 0;
}

.timeline__content p {
  margin: 0;
  color: #444;
  font-size: 15px;
  line-height: 1.7;
}

.timeline-card img {
  width: min(100%, 260px);
  height: 190px;
  object-fit: cover;
  border-radius: 14px;
  border: 2px solid #77bd1f;
  align-self: start;
}

/* Mobile */
@media (max-width: 768px) {
  .timeline-heading h2 {
    font-size: 17px;
  }

  .timeline-card {
    grid-template-columns: 1fr;
    gap: 16px;
    padding-left: 25px;
    background:
      radial-gradient(circle closest-side, var(--green) calc(100% - 1px), transparent)
      0 0 / var(--size) var(--size),
      linear-gradient(var(--green), var(--green)) 6px 0 / 2px 100%;
    background-repeat: no-repeat;
  }

  .timeline-card:first-child {
    background:
      radial-gradient(circle closest-side, var(--green) calc(100% - 1px), transparent)
      0 0 / var(--size) var(--size),
      linear-gradient(var(--green), var(--green)) 6px 0 / 2px 100%;
    background-repeat: no-repeat;
  }

  .timeline-card:nth-child(odd) img {
    grid-area: auto;
    justify-self: start;
  }

  .timeline-card img {
    width: 100%;
    height: 220px;
  }

  .timeline__content time {
    font-size: 32px;
  }
}
</style>

{% schema %}
{
  "name": "NextShine Timeline",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NextShine Roadmap"
    }
  ],
  "blocks": [
    {
      "type": "timeline",
      "name": "Timeline Item",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2026"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Launch Premium Car Care"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "NextShine introduces high-quality car wash, foam, interior, and exterior detailing products designed for everyday drivers and car lovers."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Timeline Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NextShine Timeline",
      "blocks": [
        {
          "type": "timeline",
          "settings": {
            "year": "2026",
            "title": "Brand Launch",
            "text": "NextShine launches with premium car care products focused on clean shine, safe formulas, and easy detailing at home."
          }
        },
        {
          "type": "timeline",
          "settings": {
            "year": "2027",
            "title": "Grow Product Line",
            "text": "NextShine expands into ceramic boosters, UV protectants, wheel care, interior cleaners, and complete detailing bundles."
          }
        }
      ]
    }
  ]
}
{% endschema %}