<section class="cd-banner-{{ section.id }}">

  {% if section.settings.desktop_image != blank %}
    <img
      class="cd-image desktop-image"
      src="{{ section.settings.desktop_image | image_url: width: 2500 }}"
      alt="Banner"
      loading="eager"
    >
  {% endif %}

  {% if section.settings.mobile_image != blank %}
    <img
      class="cd-image mobile-image"
      src="{{ section.settings.mobile_image | image_url: width: 1000 }}"
      alt="Mobile Banner"
      loading="eager"
    >
  {% endif %}

  <div class="cd-content">
    <a href="{{ section.settings.button_link }}" class="cd-btn">
      {{ section.settings.button_text }}
    </a>
  </div>

</section>

<style>

.cd-banner-{{ section.id }}{
  position:relative;
  width:100%;
  height:100vh;
  overflow:hidden;
  background:#000;
}

.cd-banner-{{ section.id }} .cd-image{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
}

.cd-banner-{{ section.id }} .mobile-image{
  display:none;
}

.cd-content{
  position:absolute;
  left:8%;
  bottom:12%;
  z-index:20;
}

/* PREMIUM GREEN BUTTON */

.cd-btn{
  --color:#63d110;

  padding:16px 42px;
  background:rgba(0,0,0,.45);
  backdrop-filter:blur(10px);

  border-radius:8px;
  position:relative;
  overflow:hidden;

  cursor:pointer;
  transition:.5s;

  font-weight:700;
  font-size:18px;
  letter-spacing:1px;

  border:2px solid var(--color);

  color:#fff;
  text-decoration:none;
  text-transform:uppercase;

  box-shadow:
  0 0 20px rgba(99,209,16,.25),
  0 0 40px rgba(99,209,16,.15);

  z-index:1;
}

.cd-btn::before,
.cd-btn::after{
  content:'';
  position:absolute;

  width:60px;
  height:60px;

  border-radius:50%;

  background:var(--color);

  z-index:-1;

  transition:1s ease;
}

.cd-btn::before{
  top:-30px;
  left:-30px;
}

.cd-btn::after{
  bottom:-30px;
  right:-30px;
}

.cd-btn:hover::before,
.cd-btn:hover::after{
  width:450px;
  height:450px;
}

.cd-btn:hover{
  color:#000;
}

.cd-btn:active{
  transform:scale(.97);
}

/* MOBILE */

@media screen and (max-width:749px){

  .cd-banner-{{ section.id }}{
    height:100vh;
  }

  .desktop-image{
    display:none;
  }

  .mobile-image{
    display:block !important;
  }

  .cd-content{
    left:50%;
    bottom:8%;
    transform:translateX(-50%);
    width:100%;
    text-align:center;
  }

  .cd-btn{
    font-size:15px;
    padding:14px 28px;
  }

}

</style>

{% schema %}
{
  "name": "Clean Drive Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Banner"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Banner"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Clean Drive Hero"
    }
  ]
}
{% endschema %}

