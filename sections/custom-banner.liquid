<section class="custom-banner">

  <picture>
    {% if section.settings.mobile_image != blank %}
      <source
        media="(max-width: 749px)"
        srcset="{{ section.settings.mobile_image | image_url: width: 1000 }}">
    {% endif %}

    {% if section.settings.desktop_image != blank %}
      <img
        src="{{ section.settings.desktop_image | image_url: width: 2500 }}"
        alt="{{ section.settings.alt_text }}"
        class="banner-image"
        loading="eager">
    {% endif %}
  </picture>

  {% if section.settings.button_text != blank %}
    <div class="banner-content">
      <a href="{{ section.settings.button_link }}" class="banner-btn">
        {{ section.settings.button_text }}
      </a>
    </div>
  {% endif %}

</section>

<style>

.custom-banner{
  position:relative;
  width:100%;
  height:100vh;
  overflow:hidden;
}

.custom-banner .banner-image{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

/* BUTTON */

.banner-content{
  position:absolute;
  left:8%;
  bottom:12%;
  z-index:10;
}

.banner-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;

  min-width:190px;
  height:58px;

  background:#63d110;
  color:#fff;

  text-decoration:none;
  text-transform:uppercase;

  font-size:18px;
  font-weight:800;
  letter-spacing:1px;

  border-radius:8px;

  box-shadow:0 8px 25px rgba(99,209,16,.35);

  transition:.3s ease;
}

.banner-btn:hover{
  background:#4eb100;
  transform:translateY(-2px);
}

@media screen and (max-width:749px){

  .custom-banner{
    height:100vh;
  }

  .banner-content{
    left:50%;
    transform:translateX(-50%);
    bottom:8%;
    width:100%;
    text-align:center;
  }

  .banner-btn{
    min-width:170px;
    height:52px;
    font-size:15px;
  }
}

</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Banner"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Banner"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt Text",
      "default": "Banner"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}