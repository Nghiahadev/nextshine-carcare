<section class="cd-banner">

  <div class="cd-banner-wrapper">

    <img
      class="cd-banner-img desktop-banner"
      src="{{ section.settings.desktop_image | image_url: width: 2400 }}"
      alt="Banner">

    <img
      class="cd-banner-img mobile-banner"
      src="{{ section.settings.mobile_image | image_url: width: 1000 }}"
      alt="Banner">

    <div class="cd-banner-content">
      <a href="{{ section.settings.button_link }}" class="cd-btn">
        {{ section.settings.button_text }}
      </a>
    </div>

  </div>

</section>

<style>

.cd-banner{
  width:100%;
}

.cd-banner-wrapper{
  position:relative;
}

.cd-banner-img{
  width:100%;
  display:block;
}

.mobile-banner{
  display:none;
}

/* BUTTON */

.cd-banner-content{
  position:absolute;
  left:8%;
  bottom:12%;
}

.cd-btn{
  display:inline-block;

  padding:16px 38px;

  background:#63d110;
  color:#fff;

  font-size:18px;
  font-weight:700;
  text-transform:uppercase;
  text-decoration:none;

  border-radius:8px;

  transition:.3s ease;

  box-shadow:0 10px 30px rgba(99,209,16,.35);
}

.cd-btn:hover{
  background:#4ca900;
  transform:translateY(-2px);
}

/* MOBILE */

@media(max-width:749px){

  .desktop-banner{
    display:none;
  }

  .mobile-banner{
    display:block;
  }

  .cd-banner-content{
    left:50%;
    bottom:8%;
    transform:translateX(-50%);
  }

  .cd-btn{
    padding:14px 28px;
    font-size:15px;
  }
}

</style>

{% schema %}
{
  "name":"Clean Drive Banner",
  "settings":[
    {
      "type":"image_picker",
      "id":"desktop_image",
      "label":"Desktop Banner"
    },
    {
      "type":"image_picker",
      "id":"mobile_image",
      "label":"Mobile Banner"
    },
    {
      "type":"text",
      "id":"button_text",
      "label":"Button Text",
      "default":"SHOP NOW"
    },
    {
      "type":"url",
      "id":"button_link",
      "label":"Button Link"
    }
  ],
  "presets":[
    {
      "name":"Clean Drive Banner"
    }
  ]
}
{% endschema %}