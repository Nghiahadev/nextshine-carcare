<section id="clean-drive-banner-{{ section.id }}" class="clean-drive-banner">
  <div class="clean-drive-banner__media">
    {% if section.settings.desktop_image != blank %}
      {{
        section.settings.desktop_image
        | image_url: width: 2400
        | image_tag:
          class: 'clean-drive-banner__image clean-drive-banner__image--desktop',
          loading: 'eager',
          alt: section.settings.alt_text
      }}
    {% endif %}

    {% if section.settings.mobile_image != blank %}
      {{
        section.settings.mobile_image
        | image_url: width: 1000
        | image_tag:
          class: 'clean-drive-banner__image clean-drive-banner__image--mobile',
          loading: 'eager',
          alt: section.settings.alt_text
      }}
    {% endif %}
  </div>

  {% if section.settings.button_text != blank %}
    <div class="clean-drive-banner__content">
      <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="clean-drive-banner__button">
        {{ section.settings.button_text }}
      </a>
    </div>
  {% endif %}
</section>

<style>
  #clean-drive-banner-{{ section.id }} {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    background: #000;
  }

  #clean-drive-banner-{{ section.id }} .clean-drive-banner__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #clean-drive-banner-{{ section.id }} .clean-drive-banner__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  #clean-drive-banner-{{ section.id }} .clean-drive-banner__image--mobile {
    display: none;
  }

  #clean-drive-banner-{{ section.id }} .clean-drive-banner__content {
    position: absolute;
    left: 8%;
    bottom: 12%;
    z-index: 2;
  }

  #clean-drive-banner-{{ section.id }} .clean-drive-banner__button {
    --btn-color: #63d110;

    display: inline-block;
    position: relative;
    overflow: hidden;
    z-index: 1;

    padding: 16px 42px;
    border: 2px solid var(--btn-color);
    border-radius: 8px;

    background: rgba(0, 0, 0, 0.45);
    color: #ffffff;

    font-size: 18px;
    font-weight: 700;
    letter-spacing: 1px;
    line-height: 1;
    text-transform: uppercase;
    text-decoration: none;

    cursor: pointer;
    transition: 0.45s ease;
    box-shadow: 0 0 22px rgba(99, 209, 16, 0.35);
  }

  #clean-drive-banner-{{ section.id }} .clean-drive-banner__button::before,
  #clean-drive-banner-{{ section.id }} .clean-drive-banner__button::after {
    content: "";
    position: absolute;
    width: 55px;
    height: 55px;
    border-radius: 50%;
    background: var(--btn-color);
    z-index: -1;
    transition: 0.9s ease;
  }

  #clean-drive-banner-{{ section.id }} .clean-drive-banner__button::before {
    top: -30px;
    left: -30px;
  }

  #clean-drive-banner-{{ section.id }} .clean-drive-banner__button::after {
    right: -30px;
    bottom: -30px;
  }

  #clean-drive-banner-{{ section.id }} .clean-drive-banner__button:hover::before,
  #clean-drive-banner-{{ section.id }} .clean-drive-banner__button:hover::after {
    width: 450px;
    height: 450px;
  }

  #clean-drive-banner-{{ section.id }} .clean-drive-banner__button:hover {
    color: #000000;
  }

  #clean-drive-banner-{{ section.id }} .clean-drive-banner__button:active {
    transform: scale(0.97);
  }

  @media screen and (max-width: 749px) {
    #clean-drive-banner-{{ section.id }} {
      height: 100vh;
      min-height: 650px;
    }

    #clean-drive-banner-{{ section.id }} .clean-drive-banner__image--desktop {
      display: none;
    }

    #clean-drive-banner-{{ section.id }} .clean-drive-banner__image--mobile {
      display: block;
    }

    #clean-drive-banner-{{ section.id }} .clean-drive-banner__content {
      left: 50%;
      bottom: 8%;
      width: 100%;
      text-align: center;
      transform: translateX(-50%);
    }

    #clean-drive-banner-{{ section.id }} .clean-drive-banner__button {
      padding: 14px 30px;
      font-size: 15px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop banner image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile banner image"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Image alt text",
      "default": "Custom banner"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}