<section class="nx-best-sellers">
  <div class="nx-best-wrap">

    <div class="nx-section-title">
      <span></span>
      <h2>{{ section.settings.heading }}</h2>
      <span></span>
    </div>

    <div class="nx-product-grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}

        {% if product != blank %}
          <div class="nx-product-card" {{ block.shopify_attributes }}>

            {% if block.settings.badge != blank %}
              <div class="nx-product-badge">{{ block.settings.badge }}</div>
            {% endif %}

            <a href="{{ product.url }}" class="nx-product-image">
              {% if product.featured_image != blank %}
                <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title | escape }}">
              {% endif %}
            </a>

            <h3>{{ product.title }}</h3>
            <p class="nx-price">{{ product.price | money }}</p>

            <form method="post" action="/cart/add">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button type="submit" class="nx-add-btn">
                ADD TO CART
              </button>
            </form>

          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="nx-view-all-wrap">
        <a href="{{ section.settings.button_link }}" class="nx-view-all">
          {{ section.settings.button_label }} <span>→</span>
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
@property --border-angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}

.nx-best-sellers {
  background:
    radial-gradient(circle at center, rgba(126,211,33,.12), transparent 36%),
    linear-gradient(180deg, #020602 0%, #041504 50%, #020602 100%);
  padding: 18px 20px 42px;
  color: #fff;
}

.nx-best-wrap {
  max-width: 1450px;
  margin: 0 auto;
}

.nx-section-title {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 18px;
  margin-bottom: 22px;
}

.nx-section-title span {
  height: 1px;
  background: rgba(126,211,33,.55);
}

.nx-section-title h2 {
  margin: 0;
  color: #fff;
  font-size: 23px;
  font-weight: 900;
  text-transform: uppercase;
}

.nx-product-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 18px;
}

.nx-product-card {
  position: relative;
  background: #f8f8f8;
  color: #111;
  border-radius: 10px;
  padding: 18px 16px 16px;
  text-align: center;
  min-height: 330px;
  box-shadow: 0 10px 28px rgba(0,0,0,.35);
  transition: .3s ease;
}

.nx-product-card:hover {
  transform: translateY(-5px);
}

.nx-product-badge {
  position: absolute;
  top: 14px;
  left: 12px;
  background: #4fb000;
  color: #fff;
  font-size: 10px;
  font-weight: 900;
  padding: 6px 8px;
  border-radius: 3px;
  text-transform: uppercase;
  z-index: 2;
}

.nx-product-image {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 170px;
  margin-bottom: 18px;
}

.nx-product-image img {
  max-width: 100%;
  max-height: 170px;
  object-fit: contain;
}

.nx-product-card h3 {
  margin: 0 auto 10px;
  color: #111;
  font-size: 15px;
  font-weight: 800;
  line-height: 1.3;
  min-height: 40px;
  max-width: 210px;
}

.nx-price {
  margin: 0 0 12px;
  color: #111;
  font-size: 26px;
  font-weight: 900;
}

.nx-add-btn {
  width: 150px;
  max-width: 100%;
  background: linear-gradient(180deg, #54b900, #278900);
  border: none;
  color: #fff;
  padding: 11px 16px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 900;
  cursor: pointer;
  transition: .3s ease;
}

.nx-add-btn:hover {
  background: linear-gradient(180deg, #7ed321, #3fa000);
  transform: translateY(-2px);
}

.nx-view-all-wrap {
  text-align: center;
  margin-top: 20px;
}

.nx-view-all {
  position: relative;
  overflow: hidden;

  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 14px;

  min-width: 260px;
  padding: 13px 26px;

  color: #fff;
  text-decoration: none;

  font-size: 13px;
  font-weight: 900;
  text-transform: uppercase;

  border-radius: 6px;
  background: #061206;

  z-index: 1;
  transition: .3s ease;

  box-shadow:
    0 0 0 1px rgba(126,211,33,.08),
    0 8px 20px rgba(0,0,0,.25);
}

.nx-view-all::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1.5px;

  background:
    conic-gradient(
      from var(--border-angle),
      transparent 0deg,
      transparent 260deg,
      rgba(126,211,33,.15) 290deg,
      #7ed321 320deg,
      rgba(126,211,33,.15) 350deg,
      transparent 360deg
    );

  -webkit-mask:
    linear-gradient(#000 0 0) content-box,
    linear-gradient(#000 0 0);

  -webkit-mask-composite: xor;
  mask-composite: exclude;

  animation: borderRotate 4s linear infinite;
  pointer-events: none;
}

.nx-view-all:hover {
  color: #fff;
  transform: translateY(-2px);
  box-shadow:
    0 0 15px rgba(126,211,33,.25);
}

.nx-view-all span {
  transition: transform .3s ease;
}

.nx-view-all:hover span {
  transform: translateX(5px);
}

@keyframes borderRotate {
  from {
    --border-angle: 0deg;
  }
  to {
    --border-angle: 360deg;
  }
}

@media (max-width: 1100px) {
  .nx-product-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 750px) {
  .nx-product-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .nx-product-card {
    min-height: 310px;
  }
}

@media (max-width: 480px) {
  .nx-product-grid {
    grid-template-columns: 1fr;
  }

  .nx-section-title h2 {
    font-size: 20px;
  }
}
</style>

{% schema %}
{
  "name": "Best Sellers Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BEST SELLERS"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "View all button text",
      "default": "VIEW ALL PRODUCTS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "View all button link"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "limit": 5,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Choose product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text",
          "default": "BEST SELLER"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best Sellers Grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}